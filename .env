# ---------------------------------------------------------
# StackPay Protocol — Mainnet Configuration
# ---------------------------------------------------------

# The Stacks address where your contract is deployed
# Replace ST... with SP... for Mainnet launch
NEXT_PUBLIC_STACKPAY_CONTRACT_ADDRESS=SP3FBR2AGK5H9QBDH3EEN6DF8EK8JY7RX8QJ5SVTE
NEXT_PUBLIC_STACKPAY_CONTRACT_NAME=stackpay

# Network Mode: mainnet (Production) or testnet (Development)
NEXT_PUBLIC_NETWORK=mainnet

# RPC Endpoint: Leave empty to use public Hiro nodes, 
# or add a QuickNode/AllThatNode URL for premium speed.
NEXT_PUBLIC_STACKS_API_URL=

# WalletConnect / Reown Project ID 
# Essential for mobile browser support (Leather Mobile/Xverse)
NEXT_PUBLIC_WC_PROJECT_ID=bbd019c156a90039df3f1bba9ad156fc

# Wallet Modal Branding
NEXT_PUBLIC_APP_NAME="StackPay Protocol"
NEXT_PUBLIC_APP_ICON="https://stackpay-one.vercel.app/logo.png"
